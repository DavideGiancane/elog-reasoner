        <rdfs:subClassOf rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#Act_PossibleWith_HEIGHT_Negative"/>
        <rdfs:subClassOf rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#GoingStairs"/>
    </Class>
    


    <!-- http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#GoingStairs -->

    <Class rdf:about="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#GoingStairs">
        <rdfs:subClassOf rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#Act_PossibleWith_HEIGHT_NonZero"/>
        <rdfs:subClassOf rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#Act_PossibleWith_SPEED_LOW"/>
        <rdfs:subClassOf rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#Act_PossibleWith_SPEED_MEDIUM"/>
        <rdfs:subClassOf rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#Act_PossibleWith_SPEED_Positive"/>
        <rdfs:subClassOf rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#PhysicalActivity"/>
        <rdfs:comment>HARD CONSTRAINTS (certezza -&gt; deterministic CBOX)

- Velocità positiva e non alta (vedi Disjoint with)
- Variazione di altezza non nulla

SOFT CONTRAINTS (incertezza -&gt; uncertain CBOX)

- ambiente indoor: è molto più probabile percorrere le scale in ambienti indoor

- ambiente outdoor: è molto meno probabile, ma non impossibile, fare delle scale in ambienti outdoor

- velocità bassa: è molto probabile che si percorrano le scale a velocità bassa

- velocità media: è possibile che l&#39;utente percorra le scale velocemente, ma in media come caso è meno probabile rispetto al precedente</rdfs:comment>
    </Class>
    <Axiom>
        <elog:probability rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.02185406180206007</elog:probability>
        <annotatedTarget rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#Act_PossibleWith_SPEED_MEDIUM"/>
        <annotatedSource rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#GoingStairs"/>
        <annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
    </Axiom>
    <Axiom>
        <elog:probability rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.8430914363812128</elog:probability>
        <annotatedTarget rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#Act_PossibleWith_SPEED_LOW"/>
        <annotatedSource rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#GoingStairs"/>
        <annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
    </Axiom>
    <Axiom>
        <elog:probability rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.6387631751488418</elog:probability>
        <annotatedSource rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#Act_PossibleWith_LOCATION_Outdoor"/>
        <annotatedTarget rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#GoingStairs"/>
        <annotatedProperty rdf:resource="http://www.w3.org/2002/07/owl#disjointWith"/>
    </Axiom>
    


