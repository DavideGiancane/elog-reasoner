        <rdfs:subClassOf rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#Act_PossibleWith_LOCATION_Indoor"/>
        <rdfs:subClassOf rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#Act_PossibleWith_SPEED_Null"/>
        <rdfs:subClassOf rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#PhysicalActivity"/>
        <rdfs:comment>HARD CONSTRAINTS (certezza -&gt; deterministic CBOX)

- Velocità nulla
- Variazione di altezza positiva o negativa
- Ambienti solo indoor (devono avere l&#39;ascensore - proprietà ancora non modellata)
- ??? ambiente illuminato ??? 

SOFT CONTRAINTS (incertezza -&gt; uncertain CBOX)</rdfs:comment>
    </Class>
    <Axiom>
        <elog:probability rdf:datatype="http://www.w3.org/2001/XMLSchema#double">0.7498851783023105</elog:probability>
        <annotatedSource rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#Act_PossibleWith_LOCATION_Outdoor"/>
        <annotatedTarget rdf:resource="http://ewserver.di.unimi.it/CARE/EWlab-prob-activityOnt.owl#onElevator"/>
        <annotatedProperty rdf:resource="http://www.w3.org/2002/07/owl#disjointWith"/>
    </Axiom>
    


